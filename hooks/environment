#!/bin/bash
set -ueo pipefail

PLUGIN_DIR=$(realpath $(dirname "${BASH_SOURCE[0]}")/..)

is_commit_hash() {
  echo "$1" | grep -qE '^[0-9a-f]{7,40}$'
}

plugin_ref() {
  echo "${BUILDKITE_PLUGINS:-}" | sed -n 's/.*divvun-actions\.git#\([^"]*\).*/\1/p'
}

# Buildkite caches plugin checkouts and doesn't re-fetch branches.
# When the ref is a branch name, fetch the latest so we're never stale.
PLUGIN_REF=$(plugin_ref)

if [[ -n "$PLUGIN_REF" ]] && ! is_commit_hash "$PLUGIN_REF"; then
  echo "Updating divvun-actions plugin to latest '$PLUGIN_REF'..."
  git -C "$PLUGIN_DIR" clean -ffxdq
  git -C "$PLUGIN_DIR" fetch -v --prune -- origin "$PLUGIN_REF"
  git -C "$PLUGIN_DIR" checkout -f FETCH_HEAD
  git -C "$PLUGIN_DIR" clean -ffxdq
fi

export DIVVUN_ACTIONS_PLUGIN_DIR=$PLUGIN_DIR
export PATH="$PLUGIN_DIR/bin:$PATH"

if [[ "$(uname)" == "Darwin" ]]; then
  # Ensure that the PATH is set correctly for macOS
  export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"
fi

# Set tmpdir to something we control
export TMPDIR=$(mktemp -d -t build.${BUILDKITE_PIPELINE_NAME}.${BUILDKITE_BUILD_NUMBER}.XXXXXXXXXX)
echo "Using temporary directory: $TMPDIR"

echo "Bash"
echo $PATH